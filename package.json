{
  "name": "image-processor",
  "version": "1.0.0",
  "description": "CLI tool to rename images with SEO-friendly names using AI vision and convert to WebP",
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "process": "tsx src/index.ts",
    "process:dry": "tsx src/index.ts --dry-run",
    "process:analyze": "tsx src/index.ts --analyze-only",
    "process:convert": "tsx src/index.ts --convert-only",
    "process:reset": "tsx src/index.ts --reset",
    "typecheck": "tsc --noEmit",
    "electron:dev": "tsc -p tsconfig.electron.json && electron .",
    "electron:build": "tsc -p tsconfig.electron.json",
    "dist": "npm run electron:build && electron-builder --mac --linux",
    "dist:mac": "npm run electron:build && electron-builder --mac",
    "dist:linux": "npm run electron:build && electron-builder --linux"
  },
  "build": {
    "appId": "com.image-renamer-ai.app",
    "productName": "Image Renamer AI",
    "mac": { "target": "dmg" },
    "linux": { "target": "AppImage" },
    "files": [
      "dist-electron/**/*",
      "electron/preload.cjs",
      "electron/renderer/**/*"
    ]
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "better-sqlite3": "^11.0.0",
    "cli-progress": "^3.12.0",
    "commander": "^12.0.0",
    "dotenv": "^16.0.0",
    "p-limit": "^6.0.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.0.0",
    "@types/cli-progress": "^3.0.0",
    "@types/node": "^22.0.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
